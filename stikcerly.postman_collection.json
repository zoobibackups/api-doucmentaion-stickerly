						"url": "{{stickerly}}/admin/users/{{userId}}"
					}
				},
				{
					"name": "List Packs",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/admin/packs?q=&type=&user_id=&visibility=&limit=20&offset=0"
					}
				},
				{
					"name": "Get Pack Detail (with stickers)",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/admin/packs/{{packId}}"
					}
				},
				{
					"name": "Delete Pack (admin)",
					"request": {
						"method": "DELETE",
						"url": "{{stickerly}}/admin/packs/{{packId}}"
					}
				},
				{
					"name": "Delete Sticker (admin)",
					"request": {
						"method": "DELETE",
						"url": "{{stickerly}}/admin/stickers/{{stickerId}}"
					}
				},
				{
					"name": "List Pending Pack Reports",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/admin/reports/packs?limit=50&offset=0"
					}
				},
				{
					"name": "List Pending Sticker Reports",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/admin/reports/stickers?limit=50&offset=0"
					}
				},
				{
					"name": "Resolve Pack Report",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"status\":\"dismissed\"}"
						},
						"url": "{{stickerly}}/admin/reports/packs/{{reportId}}"
					}
				},
				{
					"name": "Resolve Sticker Report",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\"status\":\"dismissed\"}"
						},
						"url": "{{stickerly}}/admin/reports/stickers/{{reportId}}"
					}
				},
				{
					"name": "List Bans",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/admin/bans"
					}
				},
				{
					"name": "Ban User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": "{{stickerly}}/admin/bans",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"userId\": {{userId}},\n  \"reason\": \"Violation of terms\"\n}"
						}
					}
				},
				{
					"name": "Unban User",
					"request": {
						"method": "DELETE",
						"url": "{{stickerly}}/admin/bans/{{userId}}"
					}
				}
			]
		}
	]
}