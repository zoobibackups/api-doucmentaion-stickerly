								"value": "application/json"
							}
						],
						"url": "{{stickerly}}/users/me/tags",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"tag_ids\": [1, 2, 3]\n}"
						}
					}
				},
				{
					"name": "Get My Profile (v2)",
					"request": {
						"method": "GET",
						"url": "{{stickerly}}/users/me/profile"
					}
				},
				{
					"name": "Get My Packs",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{stickerly}}/users/me/packs?type=created",
							"host": [
								"{{stickerly}}"
							],
							"path": [
								"users",
								"me",
								"packs"
							],
							"query": [
								{
									"key": "type",
									"value": "created",
									"description": "created | liked"
								}
							]
						}
					}
				}
			]
		},
