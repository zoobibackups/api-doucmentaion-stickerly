								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"url": "{{stickerly}}/users/me",
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"new_username\",\n  \"bio\": \"My updated bio\"\n}"
